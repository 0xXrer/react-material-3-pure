{
    "name": "react-material-3-pure",
    "version": "0.1.1",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/packages/lib/src/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/packages/lib/src/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/packages/lib/src/index.d.ts",
                "default": "./dist/index.cjs"
            }
        },
        "./styles": "./dist/styles.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "*.css"
    ],
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "devDependencies": {
        "esbuild-css-modules-plugin": "^3.1.5",
        "tsup": "^8.4.0",
        "typescript": "~5.9.3"
    },
    "scripts": {
        "build": "tsup && tsc --emitDeclarationOnly",
        "clean": "rimraf dist"
    }
}