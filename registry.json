  "hooks": {
    "useRipple": {
      "name": "useRipple",
      "description": "M3 ripple effect — state layer + Web Animations API",
      "files": [
        {
          "path": "hooks/useRipple.ts",
          "target": "useRipple.ts",
          "type": "hook"
        }
      ]
    }
  },
  "styles": {
    "theme": {
      "name": "M3 Theme",
      "description": "Design tokens — colors, elevation, shape, typography",
      "files": [
        {
          "path": "styles/theme.css",
          "target": "theme.css",
          "type": "style"
        }
      ]
