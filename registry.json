{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "m3-pure",
  "version": "0.2.0",
  "description": "Material Design 3 components for React",
  "repository": "https://github.com/user/react-material-3-pure",
  "components": {
    "button": {
      "name": "Button",
      "description": "M3 Common Button — filled, outlined, text, elevated, tonal variants",
      "files": [
        {
          "path": "components/Button/Button.tsx",
          "target": "Button/Button.tsx",
          "type": "component"
        },
        {
          "path": "components/Button/Button.module.css",
          "target": "Button/Button.module.css",
          "type": "style"
        },
        {
          "path": "components/Button/index.ts",
          "target": "Button/index.ts",
          "type": "barrel"
        }
      ],
      "hooks": [
        "useRipple"
      ],
      "styles": [
        "theme"
      ]
    },
    "checkbox": {
      "name": "Checkbox",
      "description": "M3 Checkbox — checked, unchecked, indeterminate states with animations",
